# ParkWise Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://parkwise_admin:Demo123456@cluster0.owdz7ng.mongodb.net/?appName=Cluster0

# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment
NODE_ENV=development

# JWT Secret (for authentication if implemented)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Socket.IO Configuration (optional)
SOCKET_CORS_ORIGIN=https://parkwise-fullstack.onrender.com
